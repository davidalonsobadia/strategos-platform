# Template for the ./.env that lives ON THE SERVER, next to docker-compose.prod.yml.
# Only used for INTERPOLATION of the prod compose (not the app's own .env).
# Copy it to ~/strategos-platform/.env on the VPS and fill in the values.
# Do NOT commit it with real values.

# External docker network where the VPS's entry Caddy lives (Koalvia/infra repo,
# the one that owns 80/443). strategos-caddy (its internal Caddy) hooks into this
# network so the entry Caddy can reach it at strategos-caddy:80.
PROXY_NETWORK=proxy

# Postgres credentials for the db container (use a strong password).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-something-strong
POSTGRES_DB=strategos_db

# (Optional) Pin images to a specific tag for rollback. By default CI uses
# :latest. To roll back, set the sha-XXXXXXX tag here and relaunch
# `docker compose -f docker-compose.prod.yml up -d`.
# BACKEND_IMAGE=ghcr.io/davidalonsobadia/strategos-platform-backend:sha-abc1234
# FRONTEND_IMAGE=ghcr.io/davidalonsobadia/strategos-platform-frontend:sha-abc1234
