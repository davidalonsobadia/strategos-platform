# INTERNAL Caddy for Strategos ("caddy" service / strategos-caddy container).
# Does NOT listen on the host's 80/443: that belongs to the VPS's ENTRY Caddy
# (Koalvia/infra repo), which forwards the domain over the "proxy" network:
#
#     strategos-platform.koalvia.com {
#         reverse_proxy strategos-caddy:80
#     }
#
# TLS is terminated by the entry Caddy. Here we only route plain HTTP to the
# frontend (Next.js), whose server-side route handlers talk to the backend
# (api:8000) over the internal network.

:80 {
	encode gzip
	reverse_proxy frontend:3000
}
